{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/cards/**",
              "components/content/**",
              "components/feedback/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|as|href|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, as, href, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|outline)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:a|button)$/]",
        "message": "<Button> as must be one of 'a' | 'button'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CalloutBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|onDark|children|key|ref|className|style|children)$/]",
        "message": "<CalloutBox> doesn't accept that prop. Declared props: title, onDark, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|label|title|description|meta|href|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: kind, label, title, description, meta, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:venture|pipe|coach)$/]",
        "message": "<Card> kind must be one of 'venture' | 'pipe' | 'coach'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|href|key|ref|className|style|children)$/]",
        "message": "<ContactItem> doesn't accept that prop. Declared props: label, value, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='CookieBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:visible|onAccept|onDecline|key|ref|className|style|children)$/]",
        "message": "<CookieBanner> doesn't accept that prop. Declared props: visible, onAccept, onDecline."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|detail|key|ref|className|style|children)$/]",
        "message": "<FeatureItem> doesn't accept that prop. Declared props: text, detail."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:onCookieSettings|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: onCookieSettings."
      },
      {
        "selector": "JSXOpeningElement[name.name='Nav'] > JSXAttribute > JSXIdentifier[name!=/^(?:activePath|onNavigate|logoSrc|key|ref|className|style|children)$/]",
        "message": "<Nav> doesn't accept that prop. Declared props: activePath, onNavigate, logoSrc."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHero'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|description|home|onPaper|key|ref|className|style|children)$/]",
        "message": "<PageHero> doesn't accept that prop. Declared props: eyebrow, title, description, home, onPaper."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tier'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|subtitle|features|highlighted|key|ref|className|style|children)$/]",
        "message": "<Tier> doesn't accept that prop. Declared props: name, subtitle, features, highlighted."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
